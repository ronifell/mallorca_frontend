{
  "expo": {
    "name": "Citas Mallorca",
    "slug": "citas-mallorca",
    "scheme": "citasmallorca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F2EBE0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "es.citasmallorca.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photos to upload your profile pictures.",
        "NSCameraUsageDescription": "We need access to your camera to take profile pictures."
      }
    },
    "android": {
      "package": "es.citasmallorca.app",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "navigationBar": {
        "backgroundColor": "#FFFFFF",
        "barStyle": "dark-content"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#B82E2E"
      },
      "permissions": ["NOTIFICATIONS", "INTERNET"]
    },
    "plugins": [
      ["expo-splash-screen", {
        "image": "./assets/splash.png",
        "resizeMode": "cover",
        "backgroundColor": "#F2EBE0",
        "android": {
          "statusBar": {
            "hidden": true,
            "translucent": true,
            "backgroundColor": "#F2EBE0"
          }
        }
      }],
      ["expo-image-picker", {
        "photosPermission": "Allow Citas Mallorca to access your photos to set up your profile."
      }],
      "expo-localization",
      "expo-notifications",
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "socketUrl": "http://localhost:4000"
    }
  }
}
