{
  "expo": {
    "name": "Citas Mallorca",
    "slug": "citas-mallorca",
    "scheme": "citasmallorca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2EBE0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "es.citasmallorca.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photos to upload your profile pictures.",
        "NSCameraUsageDescription": "We need access to your camera to take profile pictures.",
        "NSMicrophoneUsageDescription": "We need access to your microphone to record voice messages in chats."
      }
    },
    "android": {
      "package": "es.citasmallorca.app",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "citasmallorca",
              "host": "email-verified"
            },
            {
              "scheme": "citasmallorca",
              "host": "verify-email"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "navigationBar": {
        "backgroundColor": "#FFFFFF",
        "barStyle": "dark-content"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2EBE0"
      },
      "permissions": ["POST_NOTIFICATIONS", "INTERNET", "RECORD_AUDIO"]
    },
    "plugins": [
      ["expo-splash-screen", {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#F2EBE0",
        "android": {
          "statusBar": {
            "hidden": true,
            "translucent": true,
            "backgroundColor": "#F2EBE0"
          }
        }
      }],
      ["expo-image-picker", {
        "photosPermission": "Allow Citas Mallorca to access your photos to set up your profile."
      }],
      ["expo-av", {
        "microphonePermission": "Allow Citas Mallorca to access your microphone so you can record voice messages."
      }],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#B82E2E",
          "defaultChannel": "default"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://54.94.85.115:4000",
      "socketUrl": "http://54.94.85.115:4000"
    }
  }
}
