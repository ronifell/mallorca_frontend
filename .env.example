# Copy this file to `.env` and adjust values for your machine.
#
# Expo loads these automatically (restart `npx expo start` after changes).
# Variables prefixed with EXPO_PUBLIC_ are embedded in the app bundle — use only
# non-secret values (API URLs, feature flags). Never put JWT secrets here.
#
# localhost does NOT work on a phone or Android emulator — it refers to the device.
#
# • Physical device (Expo Go): your PC's LAN IP, e.g. http://192.168.1.42:4000
# • Android Studio emulator: http://10.0.2.2:4000 (alias for host machine)
# • iOS Simulator: http://localhost:4000 works
#
# Find your LAN IP: ipconfig (Windows) / ifconfig (Mac) — look for IPv4 on Wi‑Fi/Ethernet.

EXPO_PUBLIC_API_BASE_URL=http://54.94.85.115:4000
EXPO_PUBLIC_SOCKET_URL=http://54.94.85.115:4000

# EAS cloud builds do not read .env — set the same URLs in eas.json (build.*.env)
# or they fall back to app.json expo.extra.apiBaseUrl.
